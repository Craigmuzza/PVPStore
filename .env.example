TOKEN=
VOUCH_CHANNEL_ID=
DATA_DIR=./data
PORT=10000

# /snipe keeps a short, admin-only archive of human messages so recently
# deleted content can be recovered. Runtime content is stored under DATA_DIR.
SNIPE_RETENTION_HOURS=24
SNIPE_MAX_TRACKED_MESSAGES=10000
SNIPE_MAX_DELETED_PER_CHANNEL=25

# Groq AI roasts are optional. Leave GROQ_API_KEY blank to use static roasts only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# The Groq prank rewrites a target's entire message in a random comic voice.
# It shares GROQ_API_KEY, falls back to a local rewrite if Groq is unavailable,
# and throttles each target independently to avoid hammering the API.
PRANK_GROQ_MODEL=
PRANK_GROQ_TIMEOUT_MS=8000
PRANK_GROQ_COOLDOWN_SECONDS=15

# Restriction prank: minimum delay between a target's accepted messages.
PRANK_SLOWMODE_SECONDS=30

# Automatic roasts share one global cooldown and one per-target cooldown.
# Code-level limits prevent stale Render values from making these noisier: base
# chance <=1%, Groq share <=5%, frequency <=3x, effective chance <=3%, global
# cooldown >=60 minutes, and per-target cooldown >=360 minutes.
ROAST_CHANCE=0.01
GROQ_RANDOM_CHANCE=0.05
ROAST_MAX_FREQUENCY_MULTIPLIER=3
ROAST_RANDOM_GLOBAL_COOLDOWN_MINUTES=60
ROAST_RANDOM_TARGET_COOLDOWN_MINUTES=360

# Replies to the bot always roast back when this is 1. Set lower if you want
# some reply-chain roasts to use the static list instead.
GROQ_REPLY_CHANCE=1

# When Groq is used, this is the chance it sends a genuine compliment instead
# of dark shade. 0.5 = 50/50.
GROQ_COMPLIMENT_CHANCE=0.5

# Drive-bys use the same cooldowns. Code-level caps enforce an interval of at
# least 30 minutes and a roll no higher than 2.5%, even if Render has old values.
GROQ_DRIVEBY_ENABLED=true
GROQ_DRIVEBY_INTERVAL_MINUTES=30
GROQ_DRIVEBY_JITTER=0.2
GROQ_DRIVEBY_CHANCE=0.025
GROQ_DRIVEBY_LOOKBACK_HOURS=24

# /groqrecap fetches all 500 messages, then builds a compact timeline digest
# sized to fit the base Groq token-per-minute allowance. Leave the recap model
# blank to reuse GROQ_MODEL, or set a separate model just for summaries.
GROQ_RECAP_MODEL=
GROQ_RECAP_MAX_INPUT_CHARS=16000
GROQ_RECAP_TIMEOUT_MS=45000
GROQ_RECAP_COOLDOWN_MINUTES=5
GROQ_TIMEOUT_MS=8000
